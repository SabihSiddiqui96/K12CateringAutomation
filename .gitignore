
# Environment / secrets (keep .env.example tracked if you add one)
.env
.env.release
.env.local
.env.*.local

# Dependencies
node_modules/

# Local rerun ledger (tracks which builds were already re-run; personal, not shared)
.rerun-history.json

# Playwright output, cache, saved sessions
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/playwright/.auth/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local VS Code environment switch (personal, not shared)
.vscode/settings.json

# OS
.DS_Store
Thumbs.db

# Local-only / legacy scratch (use scripts/encryptPassword.ts)
/test-encrypt.js
/tests/placeholder/
/tests/placeholder/placeholder.ts

# Local Claude permissions (volatile, machine-specific — rewritten each session)
.claude/settings.local.json

# Personal / local-only files. Ones already committed stay tracked until you run
# `git rm --cached <file>` once — .gitignore alone won't drop a tracked file.
.gitignore
CLAUDE.md
site-map.md
scripts/ci-rerun-failed.js
scripts/rerun-failed.js
scripts/create-ticket-testcase.js

# Local-only test tooling / scratch
tests/cleanup-sabihtesting.spec.ts
rerun-fails.txt
